{
  "name": "@logiqo/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "prisma": {
    "schema": "./schema.prisma"
  },
  "scripts": {
    "db:generate": "prisma generate --schema=./schema.prisma",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "tsx src/seed.ts",
    "db:seed:demo": "tsx src/seed.ts --demo-data",
    "studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0"
  },
  "devDependencies": {
    "prisma": "^5.14.0",
    "typescript": "^5.4.0",
    "tsx": "^4.11.0",
    "@types/node": "^20.0.0"
  }
}
