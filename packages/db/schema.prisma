// LogiQo MedTech — Prisma Schema
// HIPAA-compliant PostgreSQL schema with multi-tenant Row-Level Security.
// RLS policies are applied via migration SQL (not expressible in Prisma schema).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// TENANTS & USERS
// ============================================================

model Tenant {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  slug          String    @unique
  planTier      String    @default("standard")
  baaSignedAt   DateTime?
  baaDocumentS3 String?
  isActive      Boolean   @default(true)
  settings      Json      @default("{}")

  // ── Org subscription (synced by Stripe webhook for org plans) ─────────────
  // Individual plans leave subscriptionStatus = 'none'; the User table carries
  // the individual subscription. Org plans set this field; the subscription
  // gate checks either User OR Tenant subscription status depending on plan.
  subscriptionStatus   String  @default("none") // none | active | past_due | canceled
  subscriptionTier     String?                   // org_monthly | org_annual
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  // ── Seat management ───────────────────────────────────────────────────────
  // maxUsers is set at org plan activation (pulled from Stripe metadata).
  // activeUserCount is maintained by the invite-acceptance + soft-delete flows.
  maxUsers        Int @default(20)
  activeUserCount Int @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  users                       User[]
  annotations                 Annotation[]
  comments                    Comment[]
  sops                        Sop[]
  auditLogs                   AuditLog[]
  tenantAlertAcknowledgements TenantAlertAcknowledgement[]
  invitations                 Invitation[]

  @@index([subscriptionStatus])
  @@map("tenants")
}

model User {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @db.Uuid
  auth0UserId      String    @unique
  email            String
  fullName         String
  role             String    // surgeon | hospital_safety_officer | it_procurement | org_admin | system_admin
  specialty        String?
  npiNumber        String?   @unique
  // Replaces isVerifiedClinician (boolean) — 0-3 verification tier scale:
  //   0 = Registered, email unverified (read-only)
  //   1 = Email verified via hospital domain (read + flag only)
  //   2 = NPI validated against public registry (full participation)
  //   3 = Manually reviewed by admin (trusted contributor, 1.5× vote weight)
  verificationTier        Int       @default(0)
  // Verification timestamps
  emailVerifiedAt         DateTime?
  verificationSubmittedAt DateTime? // when NPI was submitted for validation
  verificationApprovedAt  DateTime? // when tier 2 (NPI validated) or tier 3 (admin promoted)
  // Subscription fields — synced from Stripe webhooks (Phase 2: Stripe integration)
  subscriptionStatus      String    @default("none") // none | active | past_due | canceled
  subscriptionTier        String?                    // individual_monthly | individual_annual | org_monthly | org_annual
  stripeCustomerId        String?   @unique
  stripeSubscriptionId    String?   @unique
  isActive         Boolean   @default(true)
  // Soft-delete — set by DELETE /organizations/users/:id (org_admin only).
  // Hard deletes are never performed to preserve audit trail integrity.
  deletedAt        DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant                      Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  annotations                 Annotation[]                 @relation("AnnotationAuthor")
  annotationReviews           Annotation[]                 @relation("AnnotationReviewer")
  annotationEndorsements      AnnotationEndorsement[]
  annotationVotes             AnnotationVote[]
  annotationFlags             AnnotationFlag[]             @relation("FlaggedBy")
  resolvedFlags               AnnotationFlag[]             @relation("FlagResolved")
  comments                    Comment[]                    @relation("CommentAuthor")
  commentReviews              Comment[]                    @relation("CommentReviewer")
  commentVotes                CommentVote[]
  userReputation              UserReputation?
  approvedDevices             Device[]                     @relation("DeviceApprover")
  uploadedDocuments           DeviceDocument[]
  tenantAlertAcknowledgements TenantAlertAcknowledgement[] @relation("AcknowledgedBy")
  createdSops                 Sop[]                        @relation("SopCreator")
  approvedSops                Sop[]                        @relation("SopApprover")
  sentInvitations             Invitation[]                 @relation("InvitationSender")

  @@unique([tenantId, email])
  @@map("users")
}

// ── Organization invitations ──────────────────────────────────────────────────
// Created by POST /organizations/invite (org_admin only).
// Accepted via GET /auth/accept-invite?token → POST /auth/register?inviteToken.
// One active invitation per email per tenant enforced at the application layer
// (re-invite resets the token and expiresAt on the existing row).
model Invitation {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @db.Uuid
  invitedById String    @db.Uuid

  email       String
  // Role the invited user will be assigned on registration.
  // Can include org_admin — only org admins can create invitations.
  role        String

  // Cryptographically random UUID used in the invite link; never guessable.
  // DB generates it so it is always populated, even on direct DB inserts.
  token       String    @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  expiresAt   DateTime
  acceptedAt  DateTime?
  // Set by DELETE /organizations/invitations/:id to invalidate before expiry.
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy User   @relation("InvitationSender", fields: [invitedById], references: [id])

  // One active invite slot per email per tenant — prevents inbox flooding.
  // Application layer checks this and updates the existing row rather than
  // creating duplicates.
  @@unique([tenantId, email])
  @@index([token])
  @@map("invitations")
}

// ── User reputation — cumulative score derived from votes received ────────────
model UserReputation {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @unique @db.Uuid
  totalScore   Float    @default(0)
  weeklyScore  Float    @default(0)
  monthlyScore Float    @default(0)
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_reputations")
}

// ============================================================
// HARDWARE INDEX
// ============================================================

model Manufacturer {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  slug               String   @unique
  countryOfOrigin    String?
  fdaEstablishmentId String?
  contactEmail       String?
  websiteUrl         String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())

  devices Device[]

  @@map("manufacturers")
}

model DeviceCategory {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  parentId  String?  @db.Uuid
  code      String   @unique
  // Specialty hint used by the ranking algorithm's specialtyRelevanceScore
  specialtyHint String?
  createdAt DateTime @default(now())

  parent   DeviceCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children DeviceCategory[] @relation("CategoryHierarchy")
  devices  Device[]

  @@map("device_categories")
}

model Device {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sku            String
  manufacturerId String    @db.Uuid
  categoryId     String    @db.Uuid
  name           String
  description    String?
  modelNumber    String?
  version        String?

  // Regulatory
  fdA510kNumber    String?
  ceMmarkNumber    String?
  regulatoryStatus String    @default("approved") // approved | recalled | pending | withdrawn

  // Clinical data (semi-structured)
  materialComposition Json?
  dimensionsMm        Json?
  compatibilityMatrix Json?
  extractionTooling   Json?
  sterilizationMethod String?

  // Approval workflow
  approvalStatus String    @default("pending") // pending | approved | rejected
  approvedById   String?   @db.Uuid
  approvedAt     DateTime?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  manufacturer     Manufacturer     @relation(fields: [manufacturerId], references: [id])
  category         DeviceCategory   @relation(fields: [categoryId], references: [id])
  approvedBy       User?            @relation("DeviceApprover", fields: [approvedById], references: [id])
  documents        DeviceDocument[]
  annotations      Annotation[]
  alertDeviceLinks AlertDeviceLink[]

  @@unique([sku, manufacturerId])
  @@map("devices")
}

model DeviceDocument {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId      String   @db.Uuid
  documentType  String   // ifu | image | technical_spec | safety_notice
  title         String
  s3Key         String   // NEVER expose — generate pre-signed URLs only
  fileSizeBytes BigInt?
  mimeType      String?
  version       String?
  uploadedById  String?  @db.Uuid
  isCurrent     Boolean  @default(true)
  createdAt     DateTime @default(now())

  device     Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  uploadedBy User?  @relation(fields: [uploadedById], references: [id])

  @@map("device_documents")
}

// ============================================================
// PEER TELEMETRY ANNOTATIONS
// ============================================================

model Annotation {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deviceId  String @db.Uuid
  tenantId  String @db.Uuid
  authorId  String @db.Uuid

  annotationType String  // operational_friction | failure_mode | material_tolerance | tooling_anomaly | general_observation
  severity       String? // low | medium | high | critical
  title          String
  body           String
  structuredData Json?

  // Procedure context — minimized PHI
  procedureType String?
  procedureDate DateTime? @db.Date   // Date only — no timestamp to prevent PHI leakage
  patientCount  Int?                 // Aggregate count only — never individual identifiers

  // Visibility
  visibility   String  @default("tenant") // tenant | platform
  isAnonymized Boolean @default(false)

  // Moderation
  isPublished  Boolean   @default(false)
  reviewedById String?   @db.Uuid
  reviewedAt   DateTime?
  reviewNotes  String?

  // Versioning — annotations are immutable once published; corrections create a new version
  version  Int     @default(1)
  parentId String? @db.Uuid

  createdAt DateTime @default(now())
  // No updatedAt: append-only by design

  device                 Device                  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  tenant                 Tenant                  @relation(fields: [tenantId], references: [id])
  author                 User                    @relation("AnnotationAuthor", fields: [authorId], references: [id])
  reviewedBy             User?                   @relation("AnnotationReviewer", fields: [reviewedById], references: [id])
  parent                 Annotation?             @relation("AnnotationVersions", fields: [parentId], references: [id])
  versions               Annotation[]            @relation("AnnotationVersions")
  annotationEndorsements AnnotationEndorsement[]
  votes                  AnnotationVote[]
  comments               Comment[]
  tags                   AnnotationTagLink[]
  flags                  AnnotationFlag[]

  @@index([deviceId, isPublished])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("annotations")
}

model AnnotationEndorsement {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  annotationId String   @db.Uuid
  userId       String   @db.Uuid
  createdAt    DateTime @default(now())

  annotation Annotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id])

  @@unique([annotationId, userId])
  @@map("annotation_endorsements")
}

// ── Annotation votes (-1 / +1) with weighted specialty relevance ──────────────
model AnnotationVote {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  annotationId          String   @db.Uuid
  userId                String   @db.Uuid
  value                 Int      // -1 (downvote) or +1 (upvote)
  // Computed at write time:
  //   voter.specialty === device.category.specialtyHint → 1.5
  //   related specialty (static map)                   → 1.0
  //   unrelated                                        → 0.6
  specialtyRelevanceScore Float  @default(1.0)
  createdAt             DateTime @default(now())

  annotation Annotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([annotationId, userId])
  @@index([annotationId])
  @@map("annotation_votes")
}

// ── Threaded comments — append-only, max 3 nesting levels (depth 0-2) ─────────
model Comment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  annotationId String    @db.Uuid
  parentId     String?   @db.Uuid  // null = top-level; self-ref = reply
  authorId     String    @db.Uuid
  tenantId     String    @db.Uuid
  body         String
  depth        Int       @default(0) // 0 = top-level, 1 = reply, 2 = nested reply (max)
  isAnonymized Boolean   @default(false)
  isPublished  Boolean   @default(true)
  reviewedById String?   @db.Uuid
  reviewedAt   DateTime?
  // No updatedAt: append-only by design
  createdAt    DateTime  @default(now())

  annotation  Annotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  parent      Comment?   @relation("CommentThreading", fields: [parentId], references: [id])
  replies     Comment[]  @relation("CommentThreading")
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  author      User       @relation("CommentAuthor", fields: [authorId], references: [id])
  reviewedBy  User?      @relation("CommentReviewer", fields: [reviewedById], references: [id])
  votes       CommentVote[]

  @@index([annotationId, depth])
  @@index([parentId])
  @@map("comments")
}

model CommentVote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  commentId String   @db.Uuid
  userId    String   @db.Uuid
  value     Int      // -1 or +1
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@map("comment_votes")
}

// ── Tags — categorised labels attached to annotations ─────────────────────────
model AnnotationTag {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name     String
  slug     String @unique
  // device_type | specialty | material | procedure
  category String

  tagLinks AnnotationTagLink[]

  @@map("annotation_tags")
}

model AnnotationTagLink {
  annotationId String @db.Uuid
  tagId        String @db.Uuid

  annotation Annotation    @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  tag        AnnotationTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([annotationId, tagId])
  @@map("annotation_tag_links")
}

// ── Flags — clinical danger / dispute reports on annotations ──────────────────
model AnnotationFlag {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  annotationId String    @db.Uuid
  flaggedById  String    @db.Uuid
  // dangerous | inaccurate | spam | conflict_of_interest
  reason       String
  notes        String?
  resolvedById String?   @db.Uuid
  resolvedAt   DateTime?
  resolution   String?   // e.g. "removed", "disputed", "validated"
  createdAt    DateTime  @default(now())

  annotation Annotation @relation(fields: [annotationId], references: [id], onDelete: Cascade)
  flaggedBy  User       @relation("FlaggedBy", fields: [flaggedById], references: [id])
  resolvedBy User?      @relation("FlagResolved", fields: [resolvedById], references: [id])

  @@index([annotationId])
  @@index([flaggedById])
  @@map("annotation_flags")
}

// ============================================================
// ALERTS SYSTEM
// ============================================================

model Alert {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertType    String    // recall | safety_notice | field_correction | hazard_alert
  source       String    // "FDA MedWatch" | "Manufacturer" | "Manual"
  externalId   String?   // FDA recall number — used for deduplication
  title        String
  summary      String
  fullText     String?
  severity     String    // low | medium | high | critical
  affectedSkus String[]  @db.Text
  publishedAt  DateTime
  expiresAt    DateTime?
  sourceUrl    String?
  rawPayload   Json?
  ingestedAt   DateTime  @default(now())
  createdAt    DateTime  @default(now())

  alertDeviceLinks            AlertDeviceLink[]
  tenantAlertAcknowledgements TenantAlertAcknowledgement[]

  @@map("alerts")
}

model AlertDeviceLink {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertId     String   @db.Uuid
  deviceId    String   @db.Uuid
  matchMethod String   // sku_exact | sku_fuzzy | manual
  matchedAt   DateTime @default(now())

  alert  Alert  @relation(fields: [alertId], references: [id])
  device Device @relation(fields: [deviceId], references: [id])

  @@unique([alertId, deviceId])
  @@map("alert_device_links")
}

model TenantAlertAcknowledgement {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  alertId          String   @db.Uuid
  tenantId         String   @db.Uuid
  acknowledgedById String   @db.Uuid
  acknowledgedAt   DateTime @default(now())
  notes            String?

  alert          Alert  @relation(fields: [alertId], references: [id])
  tenant         Tenant @relation(fields: [tenantId], references: [id])
  acknowledgedBy User   @relation("AcknowledgedBy", fields: [acknowledgedById], references: [id])

  @@unique([alertId, tenantId])
  @@map("tenant_alert_acknowledgements")
}

// ============================================================
// SOPs
// ============================================================

model Sop {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @db.Uuid
  title        String
  version      String
  contentS3Key String
  category     String?
  effectiveDate DateTime? @db.Date
  reviewDate   DateTime? @db.Date
  status       String    @default("draft") // draft | active | archived
  createdById  String    @db.Uuid
  approvedById String?   @db.Uuid
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  createdBy  User   @relation("SopCreator", fields: [createdById], references: [id])
  approvedBy User?  @relation("SopApprover", fields: [approvedById], references: [id])

  @@map("sops")
}

// ============================================================
// IMMUTABLE AUDIT LOG
// ============================================================
// CRITICAL: The application DB user (app_user) must have
// INSERT + SELECT ONLY. No UPDATE or DELETE.
// Enforced via migration SQL:
//   REVOKE UPDATE, DELETE ON audit_logs FROM app_user;

model AuditLog {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  // Who (denormalized snapshots at time of action — never FK lookups)
  userId    String? @db.Uuid
  tenantId  String? @db.Uuid
  userEmail String?
  userRole  String?

  // What
  action       String // e.g. "annotation.vote.cast", "comment.created"
  resourceType String
  resourceId   String?

  // Change data
  oldValues Json?
  newValues Json?

  // Request context
  ipAddress String?
  userAgent String?
  requestId String?
  sessionId String?

  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

// ============================================================
// INGESTION RUNS — External API sync tracking
// ============================================================

model IngestionRun {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source            String
  status            String    @default("running")
  recordsIngested   Int       @default(0) @map("records_ingested")
  recordsSkipped    Int       @default(0) @map("records_skipped")
  errorMessage      String?               @map("error_message")
  startedAt         DateTime  @default(now()) @map("started_at")
  completedAt       DateTime?             @map("completed_at")
  triggeredBy       String    @default("manual") @map("triggered_by")
  triggeredByUserId String?   @db.Uuid @map("triggered_by_user_id")

  @@index([source, startedAt(sort: Desc)])
  @@map("ingestion_runs")
}
