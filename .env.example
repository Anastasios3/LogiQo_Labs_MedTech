# ============================================================
# LogiQo MedTech — Environment Variables
#
# HOW TO USE:
#   cp .env.example .env
#   Fill in each <placeholder> value before running
#
# SECURITY RULES:
#   .env is gitignored — NEVER commit it
#   This file must contain ONLY placeholder values, no real secrets
# ============================================================

# ── Docker local passwords ───────────────────────────────────────────────────
# Used ONLY by docker-compose.yml. Choose any strong local-only password.
# These are never used in production.
POSTGRES_PASSWORD=<choose_a_local_postgres_password>
REDIS_PASSWORD=<choose_a_local_redis_password>

# ── Database ─────────────────────────────────────────────────────────────────
# Must match POSTGRES_PASSWORD above.
DATABASE_URL="postgresql://logiqo:<your_postgres_password>@localhost:5432/logiqo_medtech"

# ── Redis ────────────────────────────────────────────────────────────────────
# Must match REDIS_PASSWORD above.
REDIS_URL="redis://:<your_redis_password>@localhost:6379"

# ── Auth0 ────────────────────────────────────────────────────────────────────
# Get these from Auth0 Dashboard → Applications
AUTH0_DOMAIN="<your-tenant>.auth0.com"
AUTH0_CLIENT_ID="<your_auth0_client_id>"
AUTH0_CLIENT_SECRET="<your_auth0_client_secret>"
AUTH0_SECRET="<generate: openssl rand -base64 32>"
AUTH0_BASE_URL="http://localhost:3000"
AUTH0_ISSUER_BASE_URL="https://<your-tenant>.auth0.com"
AUTH0_AUDIENCE="https://api.logiqo.io"
AUTH0_WEBHOOK_SECRET="<generate: openssl rand -base64 32>"

# ── AWS ──────────────────────────────────────────────────────────────────────
# Use IAM roles in production. Access keys for local dev only.
# Run infra/aws-s3-setup.sh to provision the bucket, KMS key, and IAM user.
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="<your_aws_access_key_id>"
AWS_SECRET_ACCESS_KEY="<your_aws_secret_access_key>"
S3_BUCKET="logiqo-medtech-documents-dev"
# KMS Customer-Managed Key ID for server-side S3 encryption.
# Printed by aws-s3-setup.sh. Leave blank to use the bucket's default KMS key.
KMS_KEY_ID=""

# ── API ──────────────────────────────────────────────────────────────────────
PORT="8080"
HOST="0.0.0.0"
NODE_ENV="development"
LOG_LEVEL="debug"
ALLOWED_ORIGINS="http://localhost:3000"

# Default tenant ID for first-run local dev (set after running seed)
DEFAULT_TENANT_ID=""

# Public URL of the frontend (used by /auth/verify-email redirect)
APP_URL="http://localhost:3000"

# Internal base URL of the API itself (used by email verification ticket result_url)
API_BASE_URL="http://localhost:8080"

# Secret used to sign/verify HS256 email-verification JWTs
# Generate: openssl rand -base64 32
APP_VERIFICATION_SECRET="<generate: openssl rand -base64 32>"

# Set to "true" to include the raw verification URL in POST /auth/register responses.
# dev/test ONLY — NEVER set this to "true" on staging or production servers.
EXPOSE_VERIFICATION_URL="false"

# ── Stripe ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys (test mode)
STRIPE_PUBLISHABLE_KEY="pk_test_<your_publishable_key>"
STRIPE_SECRET_KEY="sk_test_<your_secret_key>"

# Get from Stripe CLI or Dashboard → Developers → Webhooks
# Run locally: stripe listen --forward-to localhost:8080/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_<your_webhook_signing_secret>"

# Stripe Price IDs — create products/prices in the Stripe Dashboard first.
# See docs/pricing.md for the full setup guide.
STRIPE_PRICE_INDIVIDUAL_MONTHLY="price_<individual_monthly_price_id>"
STRIPE_PRICE_INDIVIDUAL_ANNUAL="price_<individual_annual_price_id>"
STRIPE_PRICE_ORG_MONTHLY="price_<org_monthly_price_id>"
STRIPE_PRICE_ORG_ANNUAL="price_<org_annual_price_id>"

# Customer Portal configuration ID (optional).
# Create at: https://dashboard.stripe.com/settings/billing/portal
# Leave blank to use Stripe's default portal configuration.
STRIPE_PORTAL_CONFIG_ID=""

# Grace window (integer days) during which a past_due subscriber retains access
# while Stripe retries the failed charge. Stripe's smart-retry schedule spans
# up to 4 days; 3 is a reasonable balance between access continuity and revenue
# protection. Set to 0 for zero-tolerance (immediate 402 on any non-active status).
# See docs/pricing.md for the full policy discussion.
SUBSCRIPTION_PAST_DUE_GRACE_DAYS="0"

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Get API key from: https://resend.com/api-keys
# Leave blank in local dev — emails are logged to the console instead of sent.
RESEND_API_KEY=""
# From address (must be a verified sender domain in Resend for production)
EMAIL_FROM="noreply@logiqo.io"

# ── Web ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:8080"
