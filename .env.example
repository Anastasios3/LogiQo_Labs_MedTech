# ============================================================
# LogiQo MedTech — Environment Variables
# Copy to .env.local for local development
# NEVER commit .env.local or .env to version control
# ============================================================

# ---- DATABASE ----
DATABASE_URL="postgresql://logiqo:localdev_only@localhost:5432/logiqo_medtech"

# ---- REDIS ----
REDIS_URL="redis://:localdev_only@localhost:6379"

# ---- AUTH0 ----
# Get these from Auth0 Dashboard → Applications
AUTH0_DOMAIN="your-tenant.auth0.com"
AUTH0_CLIENT_ID="your_client_id"
AUTH0_CLIENT_SECRET="your_client_secret"
AUTH0_SECRET="generate_with: openssl rand -base64 32"
AUTH0_BASE_URL="http://localhost:3000"
AUTH0_ISSUER_BASE_URL="https://your-tenant.auth0.com"
AUTH0_AUDIENCE="https://api.logiqo.io"
AUTH0_WEBHOOK_SECRET="generate_with: openssl rand -base64 32"

# ---- AWS ----
# Use IAM role in production. Use access keys for local dev only.
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your_access_key"
AWS_SECRET_ACCESS_KEY="your_secret_key"
S3_BUCKET="logiqo-medtech-dev"

# ---- API ----
PORT="8080"
HOST="0.0.0.0"
NODE_ENV="development"
LOG_LEVEL="debug"
ALLOWED_ORIGINS="http://localhost:3000"

# Default tenant ID for first-run local dev (set after running seed)
DEFAULT_TENANT_ID=""

# ---- WEB ----
NEXT_PUBLIC_API_URL="http://localhost:8080"
